---
// src/layouts/BlogLayout.astro
import BaseLayout from "./BaseLayout.astro";
import { formatDate } from "@/lib/utils";
import Icon from "@/components/ui/Icons.astro";
import PageTransition from "@/components/react/PageTransition.tsx";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags?: string[];
}

const { title, description, pubDate, updatedDate, heroImage, tags = [] } = Astro.props;

const pubDateISO = pubDate instanceof Date && !isNaN(pubDate.getTime())
  ? pubDate.toISOString()
  : "";
const pubDateFormatted = pubDate instanceof Date && !isNaN(pubDate.getTime())
  ? formatDate(pubDate)
  : "Unknown date";

const updatedDateISO = updatedDate instanceof Date && !isNaN(updatedDate.getTime())
  ? updatedDate.toISOString()
  : "";
const updatedDateFormatted = updatedDate instanceof Date && !isNaN(updatedDate.getTime())
  ? formatDate(updatedDate)
  : "";
---

<BaseLayout title={title} description={description} ogImage={heroImage}>
  <PageTransition client:load>
    <article class="mx-auto max-w-3xl px-6 py-16 md:py-24 pt-24 md:pt-32">
      <a
        href="/blog"
        class="mb-8 inline-flex items-center gap-2 text-sm text-muted hover:text-brand-500 transition-colors"
      >
        <Icon name="arrow-left" size={14} />
        Back to Blog
      </a>

      <header class="mb-8 md:mb-12">
        <div class="flex flex-wrap gap-2 mb-4">
          {tags.map((tag) => (
            <span class="rounded-full bg-brand-500/10 px-3 py-1 text-xs font-medium text-brand-500">
              {tag}
            </span>
          ))}
        </div>

        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
          {title}
        </h1>

        <div class="mt-4 flex items-center gap-4 text-sm text-muted">
          {pubDateISO && (
            <time datetime={pubDateISO}>{pubDateFormatted}</time>
          )}
          {updatedDateISO && (
            <span>
              (Updated: <time datetime={updatedDateISO}>{updatedDateFormatted}</time>)
            </span>
          )}
        </div>
      </header>

      {heroImage && (
        <img
          src={heroImage}
          alt={title}
          class="mb-8 md:mb-12 w-full rounded-2xl object-cover"
        />
      )}

      <div class="prose prose-zinc mx-auto dark:prose-invert prose-headings:font-semibold prose-a:text-brand-500 prose-a:no-underline hover:prose-a:underline prose-img:rounded-xl">
        <slot />
      </div>
    </article>
  </PageTransition>  
</BaseLayout>