---
// src/layouts/BaseLayout.astro
import "../styles/global.css";
import Header from "@/components/layout/Header.astro";
import DynamicFooter from "@/components/react/DynamicFooter.tsx";
import ScrollProgress from "@/components/react/ScrollProgress.tsx";
import AdminGate from "@/components/react/AdminGate.tsx";
import AnalyticsProvider from "@/components/react/AnalyticsProvider.tsx";
import PostHog from "@/components/posthog.astro";
import { createAdminClient } from "@/lib/supabase";
// PostHog and Umami loaded via inline scripts when needed

// ── Analytics config from env ──
// Set PUBLIC_ANALYTICS_PROVIDER=vercel|plausible|posthog|umami|none in .env
const analyticsProvider = import.meta.env.PUBLIC_ANALYTICS_PROVIDER ?? "vercel";

// Plausible config
const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN ?? "";

// Umami config
const umamiWebsiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID ?? "";
const umamiUrl = import.meta.env.PUBLIC_UMAMI_URL ?? "";

// Server-side fetch for footer data to avoid client-side delay
let footerData = null;
try {
  const supabase = createAdminClient();
  const { data: personal } = await supabase
    .from("personal")
    .select("name, socials, email")
    .limit(1)
    .single();
  if (personal) footerData = personal;
} catch {}

interface Props {
  title:        string;
  description?: string;
  ogImage?:     string;
}

const {
  title,
  description = "Full-Stack Developer — Building modern web experiences",
  ogImage     = "/og-image.png",
} = Astro.props;

const siteUrl      = Astro.site?.toString() ?? "https://localhost:4321";
const canonicalURL = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageURL   = new URL(ogImage, siteUrl).toString();
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Preconnect to external domains for performance -->
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://res.cloudinary.com" crossorigin />
    <link rel="preconnect" href="https://supabase.co" crossorigin />
    <link rel="preconnect" href="https://*.supabase.co" crossorigin />
    <link rel="dns-prefetch" href="//vitals.vercel-analytics.com" />
    <link rel="dns-prefetch" href="//plausible.io" />
    <link rel="dns-prefetch" href="//umami.is" />
    <link rel="dns-prefetch" href="//posthog.com" />

    <!-- Preload Inter font for faster FCP -->
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" as="style" crossorigin />

    <!-- Primary Meta Tags -->
    <title>{title} | Mohammad Zeeshan</title>
    <meta name="title"       content={`${title} | Mohammad Zeeshan`} />
    <meta name="description" content={description} />
    <link rel="canonical"    href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImageURL} />

    <!-- Twitter -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:url"         content={canonicalURL} />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"      content={ogImageURL} />

    <!-- Favicons -->
    <link rel="icon"             type="image/png"  href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon"             type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon"    href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180"   href="/apple-touch-icon.png" />
    <link rel="manifest"         href="/site.webmanifest" crossorigin="use-credentials" />

    <!-- Fonts — preloaded above, display=swap for non-blocking rendering -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
      crossorigin
    />

    <!-- Critical CSS (above-the-fold) — rest deferred -->
    <style is:inline>
      {`
        *,::before,::after{box-sizing:border-box;margin:0;padding:0}
        html{font-family:"Inter",system-ui,-apple-system,sans-serif;scroll-behavior:smooth;-webkit-font-smoothing:antialiased;font-display:optional}
        body{min-height:100vh}
        .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border-width:0}
        .fixed{position:fixed}
        .absolute{position:absolute}
        .relative{position:relative}
        .min-h-screen{min-height:100vh}
        .z-50{z-index:50}
        .mx-auto{margin-left:auto;margin-right:auto}
        .flex{display:flex}
        .h-16{height:4rem}
        .w-full{width:100%}
        .max-w-5xl{max-width:64rem}
        .items-center{align-items:center}
        .justify-between{justify-content:space-between}
        .px-6{padding-left:1.5rem;padding-right:1.5rem}
        .border-b{border-bottom-width:1px}
        .border-zinc-200\\/60{border-color:rgba(228,228,231,.6)}
        .bg-zinc-50\\/80{background-color:rgba(250,250,250,.8)}
        .text-zinc-900{color:#18181b}
        .text-zinc-500{color:#71717a}
        .text-sm{font-size:.875rem}
        .font-medium{font-weight:500}
        .tracking-tight{letter-spacing:-.025em}
        .hover\\:text-brand-500:hover{color:rgb(var(--color-brand-500))}
        .transition-colors{transition-property:color;transition-timing-function:ease;transition-duration:.3s}
        #main-content{padding-top:4rem}
      `}
    </style>

    <!-- JSON-LD -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context":  "https://schema.org",
      "@type":     "Person",
      "name":      "Mohammad Zeeshan",
      "url":       canonicalURL,
      "jobTitle":  "Full-Stack Developer",
      "sameAs": [
        "https://github.com/code-with-zeeshan",
        "https://linkedin.com/in/mohammad-zeeshan-37637a1a5",
        "https://x.com/yourusername"
      ]
    })} />

    <!-- Theme: prevent flash -->
    <script is:inline>
      (function () {
        var theme =
          typeof localStorage !== "undefined" && localStorage.getItem("theme")
            ? localStorage.getItem("theme")
            : window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        document.documentElement.classList.toggle("dark", theme === "dark");
      })();
    </script>
  </head>

  <body class="min-h-screen bg-zinc-50 text-zinc-900 dark:bg-zinc-950 dark:text-zinc-100 antialiased transition-colors duration-300">
    <!-- Skip to main content link for screen readers and keyboard users -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50
             rounded-lg bg-zinc-900 px-4 py-2 text-sm font-medium text-white
             hover:bg-brand-600 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2
             dark:bg-zinc-50 dark:text-zinc-900 dark:hover:bg-brand-500 dark:focus:ring-brand-500"
    >
      Skip to main content
    </a>
    <ScrollProgress client:load />
    <AdminGate     client:idle />
    <Header />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <DynamicFooter client:load initialData={footerData} />

    <!--
      Plug-and-play analytics provider
      Switch provider by setting PUBLIC_ANALYTICS_PROVIDER in .env:
        vercel   → Vercel Analytics (default)
        plausible → Plausible (cloud or self-hosted via env vars)
        posthog  → PostHog Analytics
        umami    → Umami Analytics
        none     → No analytics
    -->
    <AnalyticsProvider client:idle />

    {/* Analytics scripts — deferred to avoid blocking render */}
    {analyticsProvider === "vercel" && (
      <script is:inline src="https://va.vercel-scripts.com/v1/script.js" defer />
    )}
    {analyticsProvider === "plausible" && plausibleDomain && (
      <>
        <script defer src={`https://plausible.io/js/pa-UBkQJ0o4gGEULdawmWnIw.js`} data-domain={plausibleDomain} />
        <script is:inline>
          {`window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
          if(document.readyState==='complete'){plausible.init();}else{window.addEventListener('load',function(){plausible.init();});}`}
        </script>
      </>
    )}
    {analyticsProvider === "posthog" && (
      <PostHog />
    )}
    {analyticsProvider === "umami" && umamiWebsiteId && (
      <script defer src={`${umamiUrl || 'https://cloud.umami.is'}/script.js`} data-website-id={umamiWebsiteId}></script>
    )}
  </body>
</html>
