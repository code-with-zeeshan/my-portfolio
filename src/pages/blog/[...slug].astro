---
// src/pages/blog/[...slug].astro
import { getCollection, render } from "astro:content";
import BlogLayout from "@/layouts/BlogLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// ─── Safely extract date values ───
const pubDate = post.data.pubDate instanceof Date ? post.data.pubDate : new Date(post.data.pubDate);
const updatedDate = post.data.updatedDate
  ? post.data.updatedDate instanceof Date
    ? post.data.updatedDate
    : new Date(post.data.updatedDate)
  : undefined;
---

<BlogLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={pubDate}
  updatedDate={updatedDate}
  heroImage={post.data.heroImage}
  tags={post.data.tags}
>
  <Content />
</BlogLayout>