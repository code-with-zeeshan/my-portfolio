---
// src/pages/blog/index.astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import FadeIn from "@/components/react/FadeIn.tsx";
import { getCollection } from "astro:content";
import { formatDate } from "@/lib/utils";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog" description="Thoughts on web development, design, and technology.">
  <section class="mx-auto max-w-5xl px-6 py-24 pt-32">
    <FadeIn client:load>
      <div class="mb-16">
        <p class="mb-2 text-sm font-medium uppercase tracking-widest text-brand-500">Blog</p>
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Latest Articles</h1>
        <p class="mt-4 text-muted">Thoughts on web development, design, and technology.</p>
      </div>
    </FadeIn>

    <div class="space-y-8">
      {posts.map((post, idx) => (
        <FadeIn client:visible delay={idx * 0.1}>
          <a
            href={`/blog/${post.slug}`}
            class="group block rounded-2xl border border-border p-6 transition-all hover:border-brand-500/30 hover:shadow-lg dark:border-border-dark dark:hover:border-brand-500/30"
          >
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
              <div>
                <h2 class="text-xl font-semibold group-hover:text-brand-500 transition-colors">
                  {post.data.title}
                </h2>
                <p class="mt-2 text-sm text-muted line-clamp-2">
                  {post.data.description}
                </p>
                <div class="mt-3 flex flex-wrap gap-2">
                  {post.data.tags.map((tag: string) => (
                    <span class="text-xs text-muted bg-zinc-100 dark:bg-zinc-800 rounded-full px-2 py-0.5">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
              <time class="shrink-0 text-sm text-muted" datetime={post.data.pubDate.toISOString()}>
                {formatDate(post.data.pubDate)}
              </time>
            </div>
          </a>
        </FadeIn>
      ))}
    </div>
  </section>
</BaseLayout>