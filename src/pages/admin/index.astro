---
// src/pages/admin/index.astro
export const prerender = false; // Must be SSR

import AdminLayout from "@/layouts/AdminLayout.astro";
---

<AdminLayout title="Dashboard">
  <div id="admin-root"></div>
</AdminLayout>

<script>
  // Dynamically import AdminDashboard and error boundary to reduce initial bundle size
  // Astro will process this script and resolve path aliases correctly
  import('@/components/react/AdminDashboard.tsx').then(async (module) => {
    const AdminDashboard = module.default;
    const { AdminErrorBoundary } = await import('@/components/react/AdminErrorBoundary.tsx');
    const React = await import('react');
    const { createRoot } = await import('react-dom/client');
    
    const container = document.getElementById('admin-root');
    if (container) {
      const root = createRoot(container);
      // Wrap AdminDashboard with error boundary
      root.render(
        React.createElement(
          AdminErrorBoundary,
          null,
          React.createElement(AdminDashboard)
        )
      );
    }
  }).catch((err) => {
    console.error('Failed to load admin dashboard:', err);
  });
</script>