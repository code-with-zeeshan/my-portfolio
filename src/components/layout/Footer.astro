---
// src/components/layout/Footer.astro
import Icon from "@/components/ui/Icons.astro";
import MagneticHover from "@/components/react/MagneticHover.tsx";

const socials = [
  { href: "https://github.com/yourusername", icon: "github", label: "GitHub" },
  { href: "https://linkedin.com/in/yourusername", icon: "linkedin", label: "LinkedIn" },
  { href: "https://x.com/yourusername", icon: "twitter", label: "X (Twitter)" },
  { href: "mailto:you@email.com", icon: "mail", label: "Email" },
];

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-zinc-200 dark:border-zinc-800">
  <div class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-6 px-6 py-12 md:flex-row">
    <div class="flex flex-col items-center md:items-start gap-2">
      <span class="text-lg font-semibold text-zinc-900 dark:text-zinc-50">
        YN<span class="text-brand-500">.</span>
      </span>
      <p class="text-sm text-zinc-500 dark:text-zinc-400">
        Building modern web experiences.
      </p>
    </div>

    <div class="flex items-center gap-4">
      {socials.map(({ href, icon, label }) => (
        <MagneticHover client:visible strength={0.4}>
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-full p-2.5 text-zinc-500 transition-colors hover:bg-zinc-100 hover:text-zinc-900 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-zinc-50"
            aria-label={label}
          >
            <Icon name={icon} size={18} />
          </a>
        </MagneticHover>
      ))}
    </div>

    <p class="text-sm text-zinc-500 dark:text-zinc-400">
      &copy; {currentYear} Your Name. All rights reserved.
    </p>
  </div>
</footer>