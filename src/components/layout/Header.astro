---
// src/components/layout/Header.astro
import ThemeToggle from "@/components/layout/ThemeToggle.tsx";
import MobileNav from "@/components/layout/MobileNav.tsx";
import ResumeButton from "@/components/react/ResumeButton.tsx";

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/#projects", label: "Projects" },
  { href: "/blog", label: "Blog" },
  { href: "/#contact", label: "Contact" },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 z-50 w-full border-b border-zinc-200/60 bg-zinc-50/80 backdrop-blur-xl dark:border-zinc-800/60 dark:bg-zinc-950/80">
  <nav class="mx-auto flex h-16 max-w-5xl items-center justify-between px-6">
    <a href="/" class="text-lg font-semibold tracking-tight text-zinc-900 dark:text-zinc-50 hover:text-brand-500 transition-colors">
      M7Z6<span class="text-brand-500">.</span>
    </a>

    <div class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "text-sm font-medium transition-colors hover:text-brand-500",
            currentPath === link.href ? "text-brand-500" : "text-zinc-600 dark:text-zinc-400",
          ]}
        >
          {link.label}
        </a>
      ))}

      <ThemeToggle client:load />

      <ResumeButton
        client:load
        label="Resume"
        className="rounded-full bg-zinc-900 px-4 py-2 text-sm font-medium text-white transition-all hover:bg-brand-600 dark:bg-zinc-50 dark:text-zinc-900 dark:hover:bg-brand-500 dark:hover:text-white"
      />
    </div>

    <div class="flex items-center gap-4 md:hidden">
      <ThemeToggle client:load />
      <MobileNav client:load navLinks={navLinks} />
    </div>
  </nav>
</header>