---
// src/components/sections/Hero.astro
import { personal } from "@/data/personal";
import FadeIn from "@/components/react/FadeIn.tsx";
import TextReveal from "@/components/react/TextReveal.tsx";
import Icon from "@/components/ui/Icons.astro";
---

<section id="hero" class="relative flex min-h-[90vh] items-center pt-16">
  <div class="mx-auto max-w-5xl px-6 py-24">
    <FadeIn client:load>
      <div class="flex items-center gap-2 text-sm text-zinc-500 dark:text-zinc-400 mb-6">
        <span class="relative flex h-2.5 w-2.5">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-green-500"></span>
        </span>
        {personal.availability}
      </div>
    </FadeIn>

    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl text-zinc-900 dark:text-zinc-50">
      <TextReveal client:load text={`Hi, I'm`} />
      <TextReveal client:load text={personal.name} className="text-brand-500" delay={0.2} />
    </h1>

    <FadeIn client:load delay={0.4}>
      <p class="mt-4 text-xl text-zinc-500 dark:text-zinc-400 sm:text-2xl lg:text-3xl font-light">
        {personal.title}
      </p>
    </FadeIn>

    <FadeIn client:load delay={0.5}>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-zinc-600 dark:text-zinc-400">
        {personal.tagline}
      </p>
    </FadeIn>

    <FadeIn client:load delay={0.6}>
      <div class="mt-8 flex flex-wrap items-center gap-4">
        <a
          href="/#projects"
          class="inline-flex items-center gap-2 rounded-full bg-zinc-900 px-6 py-3 text-sm font-medium text-white transition-all hover:bg-brand-600 dark:bg-zinc-50 dark:text-zinc-900 dark:hover:bg-brand-500 dark:hover:text-white"
        >
          View My Work
          <Icon name="arrow-down" size={16} />
        </a>
        <a
          href="/#contact"
          class="inline-flex items-center gap-2 rounded-full border border-zinc-300 px-6 py-3 text-sm font-medium text-zinc-700 transition-colors hover:bg-zinc-100 dark:border-zinc-700 dark:text-zinc-300 dark:hover:bg-zinc-800"
        >
          Get In Touch
        </a>
      </div>
    </FadeIn>

    <FadeIn client:load delay={0.7}>
      <div class="mt-6 flex items-center gap-1 text-sm text-zinc-500 dark:text-zinc-400">
        <Icon name="map-pin" size={14} />
        {personal.location}
      </div>
    </FadeIn>
  </div>
</section>