---
// src/components/sections/Contact.astro
import { personal } from "@/data/personal";
import ContactForm from "@/components/react/ContactForm.tsx";
import FadeIn from "@/components/react/FadeIn.tsx";
import Icon from "@/components/ui/Icons.astro";
---

<section id="contact" class="py-24 bg-zinc-100 dark:bg-zinc-900/50">
  <div class="mx-auto max-w-5xl px-6">
    <FadeIn client:visible>
      <div class="mb-16 text-center">
        <p class="mb-2 text-sm font-medium uppercase tracking-widest text-brand-500">
          Get in Touch
        </p>
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl text-zinc-900 dark:text-zinc-50">
          Let's Work Together
        </h2>
        <p class="mt-4 mx-auto max-w-lg text-zinc-600 dark:text-zinc-400">
          Have a project in mind? I'd love to hear about it. Drop me a message
          and I'll get back to you within 24 hours.
        </p>
      </div>
    </FadeIn>

    {/* ── KEY: Use 12-col grid with col-span on FadeIn className ── */}
    <div class="grid gap-12 lg:grid-cols-12">

      {/* ── LEFT: Contact Info (4 of 12 cols) ── */}
      <FadeIn client:visible direction="left" className="lg:col-span-4">
        <div class="space-y-6">
          <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-brand-500/10 text-brand-500">
              <Icon name="mail" size={18} />
            </div>
            <div>
              <p class="text-sm text-zinc-500 dark:text-zinc-400">Email</p>
              <a href={`mailto:${personal.email}`} class="text-sm font-medium text-zinc-900 dark:text-zinc-50 hover:text-brand-500 transition-colors">
                {personal.email}
              </a>
            </div>
          </div>

          <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-brand-500/10 text-brand-500">
              <Icon name="github" size={18} />
            </div>
            <div>
              <p class="text-sm text-zinc-500 dark:text-zinc-400">GitHub</p>
              <a href={personal.socials.github} target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-zinc-900 dark:text-zinc-50 hover:text-brand-500 transition-colors">
                @yourusername
              </a>
            </div>
          </div>

          <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-brand-500/10 text-brand-500">
              <Icon name="linkedin" size={18} />
            </div>
            <div>
              <p class="text-sm text-zinc-500 dark:text-zinc-400">LinkedIn</p>
              <a href={personal.socials.linkedin} target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-zinc-900 dark:text-zinc-50 hover:text-brand-500 transition-colors">
                in/yourusername
              </a>
            </div>
          </div>

          {/* Extra info to fill space */}
          <div class="mt-4 rounded-xl border border-zinc-200 bg-white p-6 dark:border-zinc-800 dark:bg-zinc-900">
            <h3 class="text-sm font-semibold text-zinc-900 dark:text-zinc-50 mb-2">Quick Response</h3>
            <p class="text-sm text-zinc-600 dark:text-zinc-400">
              I typically respond within 24 hours. For urgent inquiries, please mention it in your message.
            </p>
          </div>
        </div>
      </FadeIn>

      {/* ── RIGHT: Contact Form (8 of 12 cols) ── */}
      <FadeIn client:visible direction="right" className="lg:col-span-8">
        <div class="rounded-2xl border border-zinc-200 bg-white p-8 dark:border-zinc-800 dark:bg-zinc-900">
          <ContactForm client:visible />
        </div>
      </FadeIn>
    </div>
  </div>
</section>