---
// src/components/sections/About.astro
import { personal } from "@/data/personal";
import FadeIn from "@/components/react/FadeIn.tsx";
import SkillBar from "@/components/react/SkillBar.tsx";
import Icon from "@/components/ui/Icons.astro";

const highlights = [
  { icon: "briefcase", label: "Years Experience", value: "5+" },
  { icon: "calendar", label: "Projects Completed", value: "30+" },
  { icon: "coffee", label: "Cups of Coffee", value: "∞" },
  { icon: "heart", label: "Happy Clients", value: "20+" },
];

const topSkills = [
  { name: "React / Next.js", level: 95 },
  { name: "TypeScript", level: 90 },
  { name: "Node.js", level: 85 },
  { name: "Tailwind CSS", level: 92 },
  { name: "PostgreSQL", level: 78 },
];
---

<section id="about" class="py-24 bg-zinc-100 dark:bg-zinc-900/50">
  <div class="mx-auto max-w-5xl px-6">
    <FadeIn client:visible>
      <div class="mb-16">
        <p class="mb-2 text-sm font-medium uppercase tracking-widest text-brand-500">
          About Me
        </p>
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl text-zinc-900 dark:text-zinc-50">
          Who I Am
        </h2>
      </div>
    </FadeIn>

    {/* ── USE grid with explicit col spans ── */}
    {/* FadeIn adds a wrapper div, so col-span goes on its className prop */}
    <div class="grid gap-12 lg:grid-cols-12">

      {/* ── LEFT COLUMN: Photo + Skill Bars (5 of 12 cols) ── */}
      <FadeIn client:visible direction="left" className="lg:col-span-5">
        <div>
          <div class="relative aspect-[4/5] overflow-hidden rounded-2xl border border-zinc-200 dark:border-zinc-800">
            <img
              src="/images/profile.webp"
              alt={personal.name}
              class="h-full w-full object-cover"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-500/10 to-transparent" />
          </div>

          {/* Skill Bars */}
          <div class="mt-8">
            <h3 class="mb-4 text-sm font-semibold uppercase tracking-widest text-zinc-500 dark:text-zinc-400">
              Top Skills
            </h3>
            <SkillBar client:visible skills={topSkills} />
          </div>
        </div>
      </FadeIn>

      {/* ── RIGHT COLUMN: Bio + Highlights + CTA (7 of 12 cols) ── */}
      <FadeIn client:visible direction="right" className="lg:col-span-7">
        <div class="flex h-full flex-col justify-center">
          <p class="text-lg leading-relaxed text-zinc-600 dark:text-zinc-300">
            {personal.bio}
          </p>

          <p class="mt-4 text-lg leading-relaxed text-zinc-600 dark:text-zinc-300">
            When I'm not coding, you can find me exploring new technologies,
            contributing to open-source projects, or sharing what I've learned
            through blog posts and talks.
          </p>

          <p class="mt-4 text-lg leading-relaxed text-zinc-600 dark:text-zinc-300">
            I believe in writing clean, maintainable code and creating
            intuitive user experiences. Every project is an opportunity to
            learn something new and push the boundaries of what's possible
            on the web.
          </p>

          {/* Highlights Grid */}
          <div class="mt-8 grid grid-cols-2 gap-4 sm:grid-cols-4">
            {highlights.map(({ icon, label, value }) => (
              <div class="rounded-xl border border-zinc-200 bg-white p-4 text-center dark:border-zinc-800 dark:bg-zinc-900">
                <div class="mx-auto mb-2 flex justify-center text-brand-500">
                  <Icon name={icon} size={20} />
                </div>
                <p class="text-2xl font-bold text-zinc-900 dark:text-zinc-50">{value}</p>
                <p class="text-xs text-zinc-500 dark:text-zinc-400">{label}</p>
              </div>
            ))}
          </div>

          {/* CTA */}
          <div class="mt-8 flex flex-wrap gap-4">
            <a
              href="/resume.pdf"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-full bg-zinc-900 px-6 py-3 text-sm font-medium text-white transition-all hover:bg-brand-600 dark:bg-zinc-50 dark:text-zinc-900 dark:hover:bg-brand-500 dark:hover:text-white"
            >
              Download Resume
            </a>
            <a
              href="/#contact"
              class="inline-flex items-center gap-2 rounded-full border border-zinc-300 px-6 py-3 text-sm font-medium text-zinc-700 transition-colors hover:bg-zinc-100 dark:border-zinc-700 dark:text-zinc-300 dark:hover:bg-zinc-800"
            >
              Let's Talk
            </a>
          </div>
        </div>
      </FadeIn>
    </div>
  </div>
</section>