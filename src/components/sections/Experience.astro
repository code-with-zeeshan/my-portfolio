---
// src/components/sections/Experience.astro
import { experiences } from "@/data/experience";
import FadeIn from "@/components/react/FadeIn.tsx";
---

<section id="experience" class="py-24">
  <div class="mx-auto max-w-5xl px-6">
    <FadeIn client:visible>
      <div class="mb-16">
        <p class="mb-2 text-sm font-medium uppercase tracking-widest text-brand-500">
          Career
        </p>
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl text-zinc-900 dark:text-zinc-50">
          Work Experience
        </h2>
      </div>
    </FadeIn>

    <div class="relative">
      {/* ── Timeline line ── */}
      {/* Mobile: left-4 (16px from left edge) */}
      {/* Desktop: centered at 50% */}
      <div class="absolute left-4 top-0 bottom-0 w-px bg-zinc-200 dark:bg-zinc-800 md:left-1/2 md:-translate-x-px" />

      <div class="space-y-12">
        {experiences.map((exp, idx) => (
          <FadeIn client:visible delay={idx * 0.15}>
            <div class="relative">
              {/* ── Timeline dot ── */}
              {/* Mobile: left-4, shifted left by half its width to center on the line */}
              {/* Desktop: centered at 50% */}
              <div class="absolute left-4 top-1 h-3 w-3 -translate-x-1/2 rounded-full border-2 border-brand-500 bg-zinc-50 dark:bg-zinc-950 md:left-1/2" />

              {/* ── Content ── */}
              {/* Mobile: pushed right with pl-10 (40px) so text clears the line+dot */}
              {/* Desktop: alternating sides using grid */}
              <div class:list={[
                "pl-10 md:pl-0",
                "md:grid md:grid-cols-2 md:gap-12",
              ]}>
                {idx % 2 === 0 ? (
                  <>
                    {/* Even items: content on LEFT side (desktop) */}
                    <div class="md:text-right md:pr-12">
                      <h3 class="text-lg font-semibold text-zinc-900 dark:text-zinc-50">{exp.role}</h3>
                      <p class="text-brand-500 font-medium">{exp.company}</p>
                      <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">{exp.period}</p>
                      <p class="mt-3 text-sm text-zinc-600 dark:text-zinc-400">{exp.description}</p>
                      <ul class="mt-3 space-y-1">
                        {exp.achievements.map((a) => (
                          <li class="text-sm text-zinc-600 dark:text-zinc-400">• {a}</li>
                        ))}
                      </ul>
                    </div>
                    {/* Empty right side for spacing */}
                    <div class="hidden md:block" />
                  </>
                ) : (
                  <>
                    {/* Odd items: empty left side, content on RIGHT side (desktop) */}
                    <div class="hidden md:block" />
                    <div class="md:pl-12">
                      <h3 class="text-lg font-semibold text-zinc-900 dark:text-zinc-50">{exp.role}</h3>
                      <p class="text-brand-500 font-medium">{exp.company}</p>
                      <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">{exp.period}</p>
                      <p class="mt-3 text-sm text-zinc-600 dark:text-zinc-400">{exp.description}</p>
                      <ul class="mt-3 space-y-1">
                        {exp.achievements.map((a) => (
                          <li class="text-sm text-zinc-600 dark:text-zinc-400">• {a}</li>
                        ))}
                      </ul>
                    </div>
                  </>
                )}
              </div>
            </div>
          </FadeIn>
        ))}
      </div>
    </div>
  </div>
</section>