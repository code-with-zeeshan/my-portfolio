{
  "rewrites": [
    { "source": "/blog/:path*", "destination": "/blog/:path*" },
    {
      "source": "/stats/js/script.js",
      "destination": "https://plausible.io/js/script.js"
    },
    {
      "source": "/stats/api/event",
      "destination": "https://plausible.io/api/event"
    }
  ],
  "redirects": [],
  "crons": [
    {
      "path": "/api/publish-scheduled",
      "schedule": "0 0 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*).(woff2|woff|ttf|eot|svg|png|jpg|jpeg|gif|webp|avif|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Vary", "value": "Accept" },
        { "key": "Expires", "value": "access plus 1 year" }
      ]
    },
    {
      "source": "/(.*).(css|js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, immutable" },
        { "key": "Expires", "value": "access plus 7 days" }
      ]
    },
    {
      "source": "/(.*).(html|json|xml|rss|txt)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=3600, must-revalidate" },
        { "key": "Expires", "value": "access plus 1 hour" }
      ]
    }
  ]
}